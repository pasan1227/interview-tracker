{
  "name": "hiring-os",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant AI-powered recruiting SaaS platform.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@hiring-os/web",
    "dev:marketing": "turbo run dev --filter=@hiring-os/marketing",
    "dev:workers": "turbo run dev --filter=@hiring-os/workers",
    "dev:api": "turbo run dev --filter=@hiring-os/api",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "db:generate": "yarn workspace @hiring-os/db prisma generate",
    "db:migrate": "yarn workspace @hiring-os/db prisma migrate dev",
    "db:deploy": "yarn workspace @hiring-os/db prisma migrate deploy",
    "db:seed": "yarn workspace @hiring-os/db seed",
    "db:reset": "yarn workspace @hiring-os/db prisma migrate reset",
    "db:studio": "yarn workspace @hiring-os/db prisma studio",
    "check:env": "node --env-file=.env scripts/check-env.mjs",
    "postinstall": "turbo run prisma:generate"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^6.0.3"
  },
  "packageManager": "yarn@4.12.0",
  "engines": {
    "node": ">=20"
  }
}

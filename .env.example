# Copy to .env and fill in the values. The shape here mirrors lib/env.ts —
# missing or malformed required values cause the app to fail at startup
# with a grouped error message.

# ---------------------------------------------------------------------------
# Required everywhere
# ---------------------------------------------------------------------------

# Postgres connection string used by Prisma at runtime.
# Format: postgresql://user:password@host:port/db?schema=public
DATABASE_URL=

# NextAuth v5 JWT signing secret. Must be at least 32 chars.
# Generate with:  openssl rand -base64 32
AUTH_SECRET=

# ---------------------------------------------------------------------------
# Required in production, optional in development
#
# Without these the app boots in dev (mail sends are no-ops with a Resend
# sandbox fallback) but lib/env.ts will refuse to start in production until
# they are set.
# ---------------------------------------------------------------------------

# Resend API key for transactional email (verification / reset / 2FA /
# interview schedule / feedback reminder).
RESEND_API_KEY=

# Verified sender. Must be a domain you control in Resend, otherwise mail
# lands in spam and DMARC alignment fails.
# Example: 'Interview Tracker <no-reply@interviewtracker.example.com>'
EMAIL_FROM=

# Public base URL of the deployed app, used to build links in
# transactional emails. No trailing slash.
# Example: https://interviews.example.com
NEXT_PUBLIC_APP_URL=

# ---------------------------------------------------------------------------
# Optional — OAuth providers
#
# Set both halves of a pair, or leave both blank to disable that provider.
# lib/env.ts will reject the half-configured case.
# ---------------------------------------------------------------------------

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Optional — Prisma migrate / seed
# ---------------------------------------------------------------------------

# Direct DB connection that bypasses any connection pooler.
# Use this when DATABASE_URL points at PgBouncer-in-transaction-pooling-mode
# or Supabase's pooler — Prisma Migrate needs a session-mode connection.
# If unset, prisma.config.ts and prisma/seed.ts fall back to DATABASE_URL.
DATABASE_URL_DIRECT=

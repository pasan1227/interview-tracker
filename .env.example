# Copy to .env (at the repo root — the same file is read by every
# workspace). Missing required values cause the app to fail at startup
# with a grouped error message.

# ─────────────────────────────────────────────────────────────────────
# Core
# ─────────────────────────────────────────────────────────────────────

# Postgres connection string used by Prisma at runtime.
# Format: postgresql://user:password@host:port/db?schema=public
DATABASE_URL=

# Direct DB connection that bypasses any connection pooler. Required
# when DATABASE_URL points at PgBouncer-in-transaction-pooling-mode or
# Supabase's pooler — Prisma Migrate needs a session-mode connection.
# Phase 1 RLS migration: this MUST be a privileged role; runtime
# DATABASE_URL should be a non-owner role so RLS applies.
DATABASE_URL_DIRECT=

# NextAuth v5 JWT signing secret. At least 32 chars.
# Generate with:  openssl rand -base64 32
AUTH_SECRET=

# Public base URL of the deployed app, used to build links in
# transactional emails. No trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────
# Email — Resend
# ─────────────────────────────────────────────────────────────────────

RESEND_API_KEY=
EMAIL_FROM=Hiring OS <no-reply@hiring.os>

# ─────────────────────────────────────────────────────────────────────
# OAuth providers (optional — set both halves of a pair or leave both
# blank to disable that provider)
# ─────────────────────────────────────────────────────────────────────

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────
# Redis (BullMQ, rate limit, session cache)
# ─────────────────────────────────────────────────────────────────────
# Upstash Redis: copy the "Redis URL" from the Upstash console
# (rediss://default:<token>@<endpoint>:<port>).
REDIS_URL=

# ─────────────────────────────────────────────────────────────────────
# Object storage (Cloudflare R2 by default; AWS S3 also works)
# ─────────────────────────────────────────────────────────────────────
# For R2: STORAGE_ENDPOINT = https://<account>.r2.cloudflarestorage.com
# For AWS: leave STORAGE_ENDPOINT blank; SDK derives from STORAGE_REGION.
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET=
# Optional CDN host for serving public assets (logos, etc.).
STORAGE_PUBLIC_URL=

# ─────────────────────────────────────────────────────────────────────
# Observability — Sentry + OTel
# ─────────────────────────────────────────────────────────────────────

SENTRY_DSN=
# Set if you want client-side Sentry too (same DSN is fine).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_PROFILES=0
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=hiring-os

# ─────────────────────────────────────────────────────────────────────
# Billing — Stripe
# ─────────────────────────────────────────────────────────────────────
# Use TEST keys in dev. Webhook secret is per-endpoint — get it from
# `stripe listen --forward-to localhost:3000/api/billing/webhook` in
# the Stripe CLI or from the dashboard for prod.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ─────────────────────────────────────────────────────────────────────
# Public API + workers
# ─────────────────────────────────────────────────────────────────────

API_PORT=4001
WORKER_PORT=4002
PUBLIC_API_BASE_URL=http://localhost:4001
API_RATE_LIMIT_PER_MIN=600

# Release tag stamped into Sentry + OTel. Usually a git SHA.
RELEASE=
